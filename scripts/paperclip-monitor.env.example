# Paperclip Monitor — Telegram Configuration
# Copy this to ~/.paperclip-monitor.env and fill in your values
#
# 1. Open Telegram → message @BotFather → /newbot → name it "Paperclip Monitor"
# 2. Copy the bot token below
# 3. Send any message to your new bot
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Find "chat":{"id": YOUR_NUMBER} in the response → copy it below

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
