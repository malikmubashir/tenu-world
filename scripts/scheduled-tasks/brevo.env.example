# Brevo transactional API key — copy to /Users/mmh/Documents/Claude/Projects/Tenu.World/.secrets/brevo.env
# .secrets/ is gitignored. NEVER commit real keys.
#
# Source: Brevo dashboard > SMTP & API > API Keys. Use the same key already
# set in Vercel project env (env var name BREVO_API_KEY). Scope: transactional
# send. No contacts API scope needed for the daily push.
#
# The tenu-daily-push scheduled task (~/Documents/Claude/Scheduled/tenu-daily-push)
# reads this file and posts to api.brevo.com/v3/smtp/email at 09:00 Paris.
# Without this file the daily push logs brevo=skipped_no_key and still fires
# the Telegram leg.

BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
