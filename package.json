    "@supabase/ssr": "^0.6.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@stripe/stripe-js": "^5.6.0",
    "stripe": "^17.7.0",
    "lucide-react": "^0.475.0",
    "clsx": "^2.1.1",
    "server-only": "^0.0.1",
    "@aws-sdk/client-s3": "^3.750.0",
    "zod": "^3.23.8",
    "exifr": "^7.1.3",
    "@capacitor/app": "^7.0.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/network": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
