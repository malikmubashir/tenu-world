    "tailwindcss": "^4.1.4",
    "@tailwindcss/postcss": "^4.1.4",
    "postcss": "^8.5.3",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/filesystem": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1"
