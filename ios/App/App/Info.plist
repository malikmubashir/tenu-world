<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>fr</string>
	<key>CFBundleDisplayName</key>
	<string>Tenu</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Camera usage. Mandatory: Capacitor Camera plugin fails silently without it. -->
	<key>NSCameraUsageDescription</key>
	<string>Tenu utilise l'appareil photo pour que vous puissiez documenter votre logement pièce par pièce. Les photos sont stockées sur votre téléphone jusqu'à l'envoi.</string>

	<!-- Photo library — only needed if the user can pick from the library.
	     We disable gallery picker at plugin level, but iOS still checks this
	     string exists when the plugin is linked. -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Tenu peut enregistrer une copie de vos photos de constat dans votre pellicule si vous le demandez.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Tenu accède à votre pellicule uniquement si vous souhaitez ajouter des photos déjà prises à un constat.</string>

	<!-- Face ID / biometrics — reserved for post-launch. Keep the string
	     committed so we don't need to re-submit the build when we flip it on. -->
	<key>NSFaceIDUsageDescription</key>
	<string>Tenu peut utiliser Face ID pour protéger l'accès à vos constats.</string>

	<!-- Export compliance. Tenu only uses HTTPS (TLS via WKWebView) + Apple
	     platform crypto; no custom encryption. Setting this key to false
	     skips the annual self-classification prompt in App Store Connect. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- App-to-app URL schemes we need to *open* (not be opened by).
	     Android 11+ equivalent is <queries> in the manifest. iOS 9+ requires
	     each scheme be declared up-front or `canOpenURL` returns NO. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>mailto</string>
		<string>tel</string>
		<string>https</string>
	</array>

	<!-- App Transport Security. We disable arbitrary loads and only allow
	     tenu.world domains to be hit, which is stricter than App Review's
	     default bar. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>tenu.world</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSThirdPartyExceptionRequiresForwardSecrecy</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Universal Links — the app intercepts https://tenu.world/auth/callback
	     so the magic-link email opens the app directly. Requires the
	     apple-app-site-association file served at tenu.world/.well-known/. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>world.tenu.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>tenu</string>
			</array>
		</dict>
	</array>

	<!-- Application-Boundary domains. Paired with Capacitor's
	     limitsNavigationsToAppBoundDomains=true, this hardens WKWebView
	     against navigation out of tenu.world. -->
	<key>WKAppBoundDomains</key>
	<array>
		<string>tenu.world</string>
		<string>www.tenu.world</string>
		<string>app.tenu.world</string>
	</array>
</dict>
</plist>
