# Tenu.World — .env.local template
# Fill every value, then rename to .env.local and push to Vercel via the script below.
# DO NOT COMMIT .env.local — verify `.gitignore` includes it.

# Supabase — production is tenu-world-eu-central (dsbzgrjtiklmxjozbdjv,
# eu-central-1 / Frankfurt) since the 2026-06-10 cutover. The legacy project
# umvcjasalzcgtfwsjbfw (eu-west-2) is abandoned — never point new envs at it.
# Keys: Supabase dashboard > tenu-world-eu-central > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://dsbzgrjtiklmxjozbdjv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 — from Cloudflare dashboard > R2 > Manage API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# IA — AWS Bedrock EU (replaces direct Anthropic API since 2026-05-26
# for RGPD data-residency reasons; see docs/15-Bedrock-Migration.md).
# Region MUST start with "eu-" (runtime guard in src/lib/ai/*.ts).
# IAM user needs bedrock:InvokeModel scoped to the Claude models
# Tenu uses (Haiku 4.5 + Sonnet 4.6) in eu-central-1.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Brevo — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Google Maps — Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://tenu.world

# Google OAuth gate — set to 1 ONLY after the #T028-#T037 Workspace OAuth
# client is configured on the Supabase project (Authentication > Providers).
# While unset/0 the login page shows magic-link only.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=0
