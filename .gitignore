# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor — commit native projects so signing config + entitlements
# survive across `cap add` regenerations. Build outputs and dependency
# caches stay local.
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/App/public/
ios/App/.gradle/
ios/App/.idea/
ios/.DS_Store
ios/App/.DS_Store

android/.gradle/
android/.idea/
android/build/
android/app/build/
android/captures/
android/local.properties
android/app/release/
android/app/src/main/assets/public/
android/.DS_Store
android/app/.DS_Store

# Capacitor regenerates these from out/ on every cap sync — no need
# to track the bundled web assets in either platform's tree.

# misc
.DS_Store
*.pem

# local secrets (Telegram bot, etc. — scaffolding only, never commit real tokens)
/.secrets/
!/.secrets/*.example

# push-queue used by tenu-daily-push scheduled task when Telegram creds missing
/.push-queue/

# python build artifacts from scripts/
__pycache__/
*.pyc
